# Gateway secrets, loaded by docker-compose (env_file) and substituted into
# openclaw.json's ${...} refs. Fill in real values; never commit the real .env.

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token

# Gateway operator/auth token (openclaw devices/admin auth). openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=replace-with-openssl-rand-hex-32

# Anthropic API key (the model: anthropic/claude-sonnet-4-6)
ANTHROPIC_API_KEY=replace-with-anthropic-api-key

# Tavily API key (bundled web-search provider)
TAVILY_API_KEY=replace-with-tavily-api-key
