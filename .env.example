# Shared secret for bearer auth between the gateway and the mail sidecar.
# Compose substitutes this into both services (single source = this root .env).
# Generate with:  openssl rand -hex 32
GMAIL_MCP_BEARER_TOKEN=replace-with-openssl-rand-hex-32

# Bearer auth for the Drive sidecar (separate from the mail one). openssl rand -hex 32
DRIVE_MCP_BEARER_TOKEN=replace-with-openssl-rand-hex-32

# Bearer auth for the Calendar sidecar (separate from mail/drive). openssl rand -hex 32
CALENDAR_MCP_BEARER_TOKEN=replace-with-openssl-rand-hex-32

# Per-send consent gate (M7): TOTP secret shared with your authenticator app.
# The model never sees this; sending requires a fresh 6-digit code you supply.
# Generate:  python3 -c "import secrets,base64; print(base64.b32encode(secrets.token_bytes(20)).decode())"
SEND_TOTP_SECRET=replace-with-base32-totp-secret

# Your own email addresses (comma-separated). A send addressed ONLY to these
# skips the confirmation code; any external recipient still requires it.
OWN_EMAIL_ADDRESSES=you@gmail.com,you@outlook.com,you@icloud.com

# OpenAI API key for inbound voice-note transcription (STT milestone). Read by the
# gateway's built-in media-understanding preflight (gpt-4o-transcribe). NOTE the exact
# name OPENAI_API_KEY - OpenClaw reads this specific env var. Sends voice audio to
# api.openai.com (allowlisted). Get one at platform.openai.com.
OPENAI_API_KEY=sk-replace-with-your-openai-key
